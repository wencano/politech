APP_HOST=0.0.0.0
APP_PORT=3000

# Local dev (cargo run)
DATABASE_URL=postgres://wencano:wencano@localhost:5432/politech
REDIS_URL=redis://127.0.0.1:6379

# Docker Compose / Dokploy — use service names as hosts
# DATABASE_URL=postgres://wencano:wencano@postgres:5432/politech
# REDIS_URL=redis://redis:6379

# Postgres container init (must match user/pass/db in DATABASE_URL)
POSTGRES_USER=wencano
POSTGRES_PASSWORD=wencano
POSTGRES_DB=politech

RUST_LOG=info
# 64-char hex string = 32-byte AES-256 key for encrypting credential secrets.
# Generate with: openssl rand -hex 32
APP_SECRET_KEY=change_me_to_a_64_char_hex_string_generated_with_openssl_rand
